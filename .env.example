TRADENEST_DB_PATH=./data/tradenest.sqlite3
TRADINGVIEW_PATH_TOKEN=replace-with-path-token
TRADINGVIEW_AUTH_TOKEN=replace-with-payload-token
TRADINGVIEW_MAX_STALE_SECONDS=300
TRADENEST_TIMEZONE=Europe/Amsterdam
TRADENEST_MODE=paper
TRADENEST_DAILY_LOSS_CAP_EUR=50
TRADENEST_MAX_OPEN_POSITIONS=1
TRADENEST_STRATEGY=cvd_rubric_v1
TRADENEST_ALLOWED_SYMBOLS=BTCUSDT,ETHUSDT
TRADENEST_COOLDOWN_MINUTES=15
TRADENEST_MAX_TRADES_PER_DAY=3
TRADENEST_ATR_PERIOD=14
TRADENEST_KILL_SWITCH=false
TRADENEST_STOP_LOSS_ATR_MULTIPLIER=1.5
TRADENEST_TAKE_PROFIT_ATR_MULTIPLIER=2.5
TRADENEST_DEFAULT_QUANTITY_EUR=100
TRADENEST_CLOSE_ON_COUNTER_SIGNAL=true
TRADENEST_MAX_HOLDING_BARS=20
TRADENEST_POSITION_MODE=one_way
TRADENEST_PRICE_FEED_ENABLED=true
TRADENEST_PRICE_FEED_PROVIDER=bybit_public_rest
TRADENEST_PRICE_FEED_CATEGORY=linear
TRADENEST_PRICE_FEED_BASE_URL=https://api.bybit.com
TRADENEST_PRICE_FEED_POLL_INTERVAL_SECONDS=30
TRADENEST_PRICE_FEED_REQUEST_TIMEOUT_SECONDS=5
TRADENEST_SCHEDULER_AUTOSTART=false
TRADENEST_TELEGRAM_ENABLED=true
TRADENEST_TELEGRAM_BOT_TOKEN_ENV=TELEGRAM_BOT_TOKEN
TRADENEST_TELEGRAM_ALLOWED_CHAT_ID_ENV=TELEGRAM_ALLOWED_CHAT_ID
TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
TELEGRAM_ALLOWED_CHAT_ID=replace-with-chat-id
TRADENEST_BACKEND_URL=http://127.0.0.1:8000
TRADENEST_DASHBOARD_URL=http://127.0.0.1:3000
TRADENEST_BACKUP_DIR=./backups
TRADENEST_LOG_DIR=./logs
TRADENEST_MIN_DISK_FREE_MB=1024
